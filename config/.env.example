# ============================================================
# Christopher Musamali Portfolio — Environment Config
# Copy this to .env and fill in real values.
# NEVER commit .env to version control (it's in .gitignore)
# ============================================================

# --- Site identity ---
SITE_NAME="Christopher Musamali Portfolio"
SITE_URL="https://lakers-tech.wuaze.com"
CONTACT_EMAIL="christophermusamali27@gmail.com"

# --- Analytics / Visitor tracking ---
# If using Google Analytics:
GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# If using a custom visitor counter endpoint:
VISITOR_API_ENDPOINT="https://your-api.example.com/visits"
VISITOR_API_KEY="your-secret-key-here"

# --- Email / Contact form ---
# If wiring the contact form to a backend (e.g. Formspree, EmailJS):
EMAILJS_SERVICE_ID="service_xxxxxxx"
EMAILJS_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_PUBLIC_KEY="your_public_key"
# Or Formspree:
FORMSPREE_ENDPOINT="https://formspree.io/f/xxxxxxxxxxx"

# --- Environment ---
APP_ENV="production"   # development | staging | production
DEBUG="false"
